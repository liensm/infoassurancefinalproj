{
  "manifest_version": 3,
  "name": "SecureText",
  "version": "1.0",
  "description": "Encrypt or decrypt highlighted text",

  "permissions": [
    "sidePanel",
    "activeTab",
    "tabs",
    "scripting"
  ],

  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_title": "SecureText",
    "default_icon": "icon.png"
  },

  "side_panel": {
    "default_path": "extension.html"
  },

  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
