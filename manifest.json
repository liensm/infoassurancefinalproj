{
  "manifest_version": 3,
  "name": "Cipher Highlighter",
  "version": "1.0",
  "description": "Encrypt or decrypt highlighted text",

  "permissions": [
    "sidePanel",
    "activeTab",
    "tabs",
    "scripting"
  ],

  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_title": "Cipher Highlighter"
  },

  "side_panel": {
    "default_path": "extension.html"
  }
}
